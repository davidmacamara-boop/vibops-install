# ============================================================
# VibOps — Environment variables
# ============================================================
# Copy this file to ".env" and fill in the values.
#   cp .env.example .env
# Never commit .env to git (see .gitignore).
# ============================================================


# ─── Licence ─────────────────────────────────────────────────
# Your VibOps licence key — provided by VibOps at contract signing.
# Without a key, VibOps runs in trial mode (14 days, limited to
# 10 GPUs / 5 users / 2 clusters). Contact david@vibops.ai to get a key.
VIBOPS_LICENCE_KEY=

# ─── Database ────────────────────────────────────────────────
# Generated automatically by: make quickstart
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://vibops:${POSTGRES_PASSWORD}@postgres:5432/vibops_db


# ─── Redis (Celery broker) ───────────────────────────────────
REDIS_URL=redis://redis:6379/0


# ─── Security ────────────────────────────────────────────────
# Change in production — use: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Vault: Fernet encryption key for secrets stored in DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=


# ─── JWT / Auth ──────────────────────────────────────────────
# Leave AUTH_PASSWORD_HASH empty to disable auth (dev mode).
# Production:
#   1. docker compose run --rm core python -c \
#        "from app.auth import hash_password; print(hash_password('your-password'))"
#   2. Paste the result in AUTH_PASSWORD_HASH below.
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
JWT_SECRET_KEY=change-me-jwt-secret-in-production
JWT_EXPIRE_HOURS=24


# ─── LLM Provider ────────────────────────────────────────────
# Choose one: claude | openai | ollama
LLM_PROVIDER=claude

# Anthropic (claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (openai) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama (ollama) — local/on-prem, no API key required
# docker-compose: http://ollama:11434  |  local dev: http://localhost:11434
OLLAMA_URL=http://ollama:11434


# ─── Datadog (optional) ──────────────────────────────────────
# Leave empty to disable.
# Get keys at: https://app.datadoghq.com/organization-settings/api-keys
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com


# ─── Git provider (optional) ─────────────────────────────────
# Choose: github | gitlab
GIT_PROVIDER=github

# Personal Access Token — scope: repo:read (GitHub) or read_api (GitLab)
# GitHub: https://github.com/settings/tokens
# GitLab: https://gitlab.example.com/-/profile/personal_access_tokens
GIT_TOKEN=

# Base URL for self-hosted GitLab (leave empty or default for gitlab.com)
GIT_URL=https://gitlab.com

# Shared secret for incoming webhooks
# GitHub: Repo > Settings > Webhooks
# GitLab: Repo > Settings > Integrations
GITHUB_WEBHOOK_SECRET=


# ─── Grafana (optional — observability profile) ──────────────
# Public Grafana URL reachable from the browser.
# Enable: docker compose --profile observability up
# Default: http://localhost:3000
GRAFANA_PUBLIC_URL=http://localhost:3000
GRAFANA_PASSWORD=vibops


# ─── Connect Gateway (optional — connect profile) ────────────
# Generate via VibOps console → Connect tab → Register gateway
CONNECT_GATEWAY_ID=
CONNECT_TOKEN=


# ─── Email (SMTP) — password reset + alerts ──────────────────
# Leave SMTP_HOST empty to disable (dev mode: token shown in UI).
# Examples:
#   Gmail/Workspace : smtp.gmail.com        port 587  (App Password required)
#   SendGrid        : smtp.sendgrid.net     port 587  user=apikey  password=SG.xxx
#   AWS SES         : email-smtp.<region>.amazonaws.com  port 587
#   Mailgun         : smtp.mailgun.org      port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com


# ─── Internal URLs (docker-compose — do not change) ──────────
CORE_API_URL=http://core:8000
AGENT_API_URL=http://agent:8001
